# ── Language Model ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── PostgreSQL Database (Cloud - Supabase) ──
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_supabase_password_here

# ── PostgreSQL Database (Local) ──
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=capstone_rag
# DB_USER=postgres
# DB_PASS=your_local_password_here

# ── Pinecone Vector Database ──
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=investigative-rag

# ── HuggingFace Embeddings ──
HF_TOKEN=your_huggingface_token_here

# ── ChromaDB (Local only) ──
CHROMA_PATH=./chroma_db
IRS_COLLECTION=irs_filings_25k
FEC_COLLECTION=fec_filings
TOP_K=5

# ── API Server ──
FRONTEND_URL=http://localhost:5173
API_PORT=8000

# ── Live Deployment URLs ──
# Frontend: https://capstone-group2-investigative-rag.vercel.app
# Backend:  https://capstone-group2-investigative-rag.onrender.com
